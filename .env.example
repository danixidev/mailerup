# Entorno de Docker Compose (raíz). Cópialo a `.env` y edita los valores.
# NO se versiona (está en .gitignore).

# --- PostgreSQL (contenedor `db`) ---
POSTGRES_DB=mailerup
POSTGRES_USER=mailerup
POSTGRES_PASSWORD=cambia-esto-por-una-contraseña-fuerte

# Conexión que usa el backend `web` para llegar al servicio `db`.
# Debe llevar EXACTAMENTE el mismo usuario/contraseña/db de arriba.
DATABASE_URL=postgres://mailerup:cambia-esto-por-una-contraseña-fuerte@db:5432/mailerup

# Puerto local (127.0.0.1) donde el contenedor nginx publica la app.
# El nginx/Cloudflare del host hace proxy_pass a este puerto.
NGINX_HOST_PORT=8110
